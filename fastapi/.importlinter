[importlinter]
root_packages =
    ontology
    titanic
    kayfabe
    superstar
    admin
    heyman
    soccer
    auth

# 하네스 계약 목록 — 위반 시 CI 차단
include_extra_contracts = True
contracts =
    star_topology_hub_only
    clean_architecture_layers
    no_spoke_to_spoke
    auth_isolation


# ────────────────────────────────────────────
# 계약 1: 스포크 간 직접 import 금지
# 스타 토폴로지의 핵심 규칙 — 스포크는 반드시 허브(ontology)를 통해서만 연결된다.
# ────────────────────────────────────────────
[importlinter:contract:no_spoke_to_spoke]
name = Spoke modules must not import each other directly
type = forbidden
source_modules =
    titanic
    kayfabe
    superstar
    admin
    heyman
    soccer
    auth
forbidden_modules =
    titanic
    kayfabe
    superstar
    admin
    heyman
    soccer
    auth
exclude_type_checking_imports = True


# ────────────────────────────────────────────
# 계약 2: 스포크는 허브(ontology)를 import할 수 있다
# ontology는 공유 커널(shared kernel)로 최하위 레이어에 위치하며,
# 스포크가 허브의 공통 유틸/컨텍스트를 사용하는 것은 허용한다.
# 반대로 허브가 스포크를 import하는 것은 금지한다.
# ────────────────────────────────────────────
[importlinter:contract:star_topology_hub_only]
name = Only hub (ontology) may import spoke modules
type = layers
layers =
    titanic | kayfabe | superstar | admin | heyman | soccer
    ontology


# ────────────────────────────────────────────
# 계약 3: 클린 아키텍처 계층 의존성 방향
# adapter → app → domain. 역방향 즉시 차단.
# 각 앱 내부에서 동일하게 적용된다.
# ────────────────────────────────────────────
[importlinter:contract:clean_architecture_layers]
name = Clean Architecture layer ordering within each app
type = layers
containers =
    titanic
    kayfabe
    superstar
    admin
    heyman
    soccer
    auth
layers =
    adapter
    app
    domain


# ────────────────────────────────────────────
# 계약 4: auth는 그 누구도 import할 수 없다 (허브 ontology 포함)
# 검증이 필요하면 core.security만 사용한다 — core는 root_packages 밖의
# 공유 커널이라 이 계약의 source_modules에 넣지 않아도(넣을 수도 없음) 이미 열려 있다.
# ────────────────────────────────────────────
[importlinter:contract:auth_isolation]
name = auth is not importable by any other app (including the hub)
type = forbidden
source_modules =
    ontology
    titanic
    kayfabe
    superstar
    admin
    heyman
    soccer
forbidden_modules =
    auth
